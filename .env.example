# ===== データベース（PostgreSQL に統一）=====
# schema.prisma の provider は "postgresql"。開発・本番ともに PostgreSQL を使う。
# 開発: ローカルの PostgreSQL（例）
DATABASE_URL="postgresql://ess:ess@localhost:5432/english_circle"
# 本番: Render の Internal Database URL（Render が自動注入するため .env への記載は不要）
# DATABASE_URL="postgresql://user:pass@host:5432/english_circle"

# ===== JWT（Flask が発行・検証 / Next.js middleware が検証）=====
JWT_SECRET="change-me"
JWT_ACCESS_EXPIRES_MIN=15
JWT_REFRESH_EXPIRES_DAYS=14

# ===== URL =====
FLASK_API_BASE_URL="http://localhost:5000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ===== seed 用 初期管理者（実値は .env にのみ記載。ここはプレースホルダ）=====
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me"
SEED_ADMIN_NAME="ESS Admin"
