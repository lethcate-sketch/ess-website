{
  "name": "ess-website",
  "version": "0.1.0",
  "private": true,
  "description": "ESS（英語ディスカッションサークル）公式サイト — Prisma スキーマ/マイグレーション/seed（真実源）",
  "scripts": {
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:local:schema": "node prisma/local-sqlite.mjs",
    "db:local": "node prisma/local-sqlite.mjs && prisma db push --schema prisma/schema.local.prisma && prisma generate --schema prisma/schema.local.prisma"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
